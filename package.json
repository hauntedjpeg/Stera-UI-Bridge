{
  "name": "stera-ui-bridge",
  "version": "0.1.0",
  "description": "Figma plugin that exports Figma variables as a paste-ready globals.css for Stera-UI projects.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "build": "pnpm run build:ui && pnpm run build:code",
    "build:ui": "vite build",
    "build:code": "esbuild src/code.ts --bundle --outfile=dist/code.js --target=es6",
    "dev": "concurrently \"vite build --watch\" \"esbuild src/code.ts --bundle --outfile=dist/code.js --target=es6 --watch\"",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.ui.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.123.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^3.2.0"
  }
}
